# ─── Normalización de line endings ──────────────────────
* text=auto eol=lf

# ─── Source code ────────────────────────────────────────
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.cjs  text eol=lf

# ─── Configuración ──────────────────────────────────────
*.yaml text eol=lf
*.yml  text eol=lf
*.env  text eol=lf

# ─── Binarios — no modificar ────────────────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.exe  binary
*.pak  binary
*.asar binary
